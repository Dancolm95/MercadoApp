@model MercadoApp.Models.Pago

@{
    ViewData["Title"] = "Registrar Pago";
}

<h2>Registrar Pago</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form id="formCrearPago" asp-action="Create" method="post">
            <div class="mb-3">
                <label asp-for="IdDeuda" class="form-label"></label>
                <select asp-for="IdDeuda" class="form-select" asp-items="ViewBag.Deudas">
                    <option value="">-- Seleccione una deuda pendiente --</option>
                </select>
                <span asp-validation-for="IdDeuda" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="IdPersona" class="form-label"></label>
                <select asp-for="IdPersona" class="form-select" asp-items="ViewBag.Personas">
                    <option value="">-- Seleccione la persona que paga --</option>
                </select>
                <span asp-validation-for="IdPersona" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="MontoPagado" class="form-label"></label>
                <input asp-for="MontoPagado" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="MontoPagado" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="FechaPago" class="form-label"></label>
                <input asp-for="FechaPago" class="form-control" type="date" />
                <span asp-validation-for="FechaPago" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="Referencia" class="form-label"></label>
                <input asp-for="Referencia" class="form-control" placeholder="Opcional: N° de comprobante u operación" />
                <span asp-validation-for="Referencia" class="text-danger"></span>
            </div>

            <div id="alertMessage" class="alert d-none" role="alert"></div>

            <div class="mb-3">
                <button type="submit" class="btn btn-primary">Registrar Pago</button>
                <a asp-action="Index" class="btn btn-secondary">Volver al listado</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        document.getElementById('formCrearPago').addEventListener('submit', function (e) {
            e.preventDefault(); // Prevenir recarga
            
            // Validar form
            if (!$(this).valid()) return;

            const data = {
                IdDeuda: parseInt(document.getElementById('IdDeuda').value),
                IdPersona: parseInt(document.getElementById('IdPersona').value),
                MontoPagado: parseFloat(document.getElementById('MontoPagado').value),
                FechaPago: document.getElementById('FechaPago').value,
                Referencia: document.getElementById('Referencia').value
            };

            fetch('/api/pagos', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(data)
            })
            .then(response => {
                if (response.ok) {
                    return response.json();
                }
                throw new Error('Error al registrar el pago');
            })
            .then(result => {
                const alertDiv = document.getElementById('alertMessage');
                alertDiv.className = 'alert alert-success mt-3';
                alertDiv.textContent = '¡Pago registrado exitosamente!';
                document.getElementById('formCrearPago').reset();
            })
            .catch(error => {
                const alertDiv = document.getElementById('alertMessage');
                alertDiv.className = 'alert alert-danger mt-3';
                alertDiv.textContent = error.message;
            });
        });
    </script>
}
