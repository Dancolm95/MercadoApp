@model MercadoApp.Models.ReporteDeudaViewModel

@{
    ViewData["Title"] = "Reporte de Deudas";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Reporte de Deudas</h2>
    <div>
        <a asp-action="Index" class="btn btn-secondary">Nuevo Reporte</a>
        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-primary">Dashboard</a>
    </div>
</div>

<div class="alert alert-info">
    <strong>Período:</strong> @ViewBag.FechaInicio hasta @ViewBag.FechaFin
</div>

<div class="row mb-3">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5>Total Deudas: @Model.Cantidad</h5>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5>Monto Total: @Model.TotalMonto.ToString("C")</h5>
            </div>
        </div>
    </div>
</div>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Puesto</th>
            <th>Tipo Servicio</th>
            <th>Monto</th>
            <th>Fecha</th>
            <th>Estado</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Deudas)
        {
            <tr>
                <td>@item.IdDeuda</td>
                <td>@item.NumeroPuesto</td>
                <td>@item.TipoServicio</td>
                <td>@item.Monto.ToString("C")</td>
                <td>@item.FechaGenerada.ToShortDateString()</td>
                <td>
                    @if (item.Pagada)
                    {
                        <span class="badge bg-success">Pagada</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Pendiente</span>
                    }
                </td>
            </tr>
        }
        @if (!Model.Deudas.Any())
        {
            <tr><td colspan="6" class="text-center">No hay deudas en este período</td></tr>
        }
    </tbody>
</table>