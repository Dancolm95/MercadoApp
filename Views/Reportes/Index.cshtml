@{
    ViewData["Title"] = "Reportes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Reportes del Mercado</h2>
    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-secondary">Volver al Dashboard</a>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Reporte de Deudas</h5>
            </div>
            <div class="card-body">
                <form asp-controller="Reportes" asp-action="Deudas" method="post">
                    <div class="mb-3">
                        <label class="form-label">Fecha Inicio</label>
                        <input type="date" name="fechaInicio" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-01")" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Fecha Fin</label>
                        <input type="date" name="fechaFin" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" required>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Generar Reporte</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">Reporte de Ingresos</h5>
            </div>
            <div class="card-body">
                <form asp-controller="Reportes" asp-action="Pagos" method="post">
                    <div class="mb-3">
                        <label class="form-label">Fecha Inicio</label>
                        <input type="date" name="fechaInicio" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-01")" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Fecha Fin</label>
                        <input type="date" name="fechaFin" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" required>
                    </div>
                    <button type="submit" class="btn btn-success w-100">Generar Reporte</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0">Reporte de Puestos</h5>
            </div>
            <div class="card-body">
                <form asp-controller="Reportes" asp-action="Puestos" method="post">
                    <div class="mb-3">
                        <label class="form-label">Estado</label>
                        <select name="estado" class="form-select">
                            <option value="Todos">Todos</option>
                            <option value="Libre">Libre</option>
                            <option value="Alquilado">Alquilado</option>
                            <option value="Vendido">Vendido</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-info w-100">Generar Reporte</button>
                </form>
            </div>
        </div>
    </div>
</div>