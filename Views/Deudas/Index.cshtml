@model IEnumerable<MercadoApp.Models.Deuda>

@{
    ViewData["Title"] = "Gestión de Deudas";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Gestión de Deudas</h2>
    <a asp-action="Create" class="btn btn-primary">+ Registrar Deuda</a>
</div>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Mensaje"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form method="get" class="mb-3 d-flex gap-2 align-items-end">
    <div>
        <label for="pagada" class="form-label">Filtrar por Estado:</label>
        <select name="pagada" id="pagada" class="form-select">
            <option value="">Todas</option>
            <option value="true">Pagadas</option>
            <option value="false">Pendientes</option>
        </select>
    </div>
    <button type="submit" class="btn btn-secondary">Filtrar</button>
</form>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Puesto</th>
            <th>Tipo de Servicio</th>
            <th>Monto</th>
            <th>Fecha Generada</th>
            <th>Estado</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.NumeroPuesto</td>
                <td>@item.TipoServicio</td>
                <td>@item.Monto.ToString("C")</td>
                <td>@item.FechaGenerada.ToShortDateString()</td>
                <td>
                    @if (item.Pagada)
                    {
                        <span class="badge bg-success">Pagada</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Pendiente</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
